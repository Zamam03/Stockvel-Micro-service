# Firebase Configuration
# Get these from: https://console.firebase.google.com/
# Project Settings > General > Your Apps > Web

VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Service Account Key
# Get from: https://console.firebase.google.com/
# Project Settings > Service Accounts > Generate New Private Key
# Save as: shared/firebase/firebaseServiceAccountKey.json

# Stripe API Key
# Get from: https://dashboard.stripe.com/apikeys
# Use test key for development, live key for production
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# Yoco API Key (Alternative to Stripe)
# Get from: https://www.yoco.com/
YOCO_API_KEY=your_yoco_key_here

# Service Configuration
PORT=5000
NODE_ENV=development

# Microservice URLs (for docker-compose)
AUTH_SERVICE_URL=http://auth:4001
PAYMENT_SERVICE_URL=http://payments:4002
STOCKVEL_SERVICE_URL=http://stockvel:4003
MEETING_SERVICE_URL=http://meetings:4004
ANALYTICS_SERVICE_URL=http://analytics:4005

# SARB Data Source (when integrating real rates)
# SARB_API_URL=https://www.sarb.co.za/
# SARB_UPDATE_FREQUENCY=daily

# Database (Firebase handles this, but for reference)
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
